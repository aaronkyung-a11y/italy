  "shortcuts": [
    {
      "name": "명소 분석",
      "short_name": "명소",
      "description": "카메라로 명소·작품 식별",
      "url": "/?action=photo",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "영수증 분석",
      "short_name": "영수증",
